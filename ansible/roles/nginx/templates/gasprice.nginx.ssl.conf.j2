# Managed by Ansible — do not edit manually on the server.
#
# Full HTTPS config with HTTP→HTTPS redirect and HSTS.
# Deployed by the certbot role after the certificate is obtained.

# HTTP: redirect everything to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }};
    return 301 https://$host$request_uri;
}

# HTTPS: the real vhost
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name {{ domain }};

    root {{ webroot }};
    index index.html;

    ssl_certificate     /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;

    # Mozilla SSL Configuration Generator — intermediate profile
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # HSTS: browsers remember to always use HTTPS for this domain (1 year)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    location / {
        try_files $uri $uri/ =404;
    }
}
